# Proxy API calls to Railway backend — avoids CORS entirely
/proxy/gateway/*  https://backforge.up.railway.app/:splat  200
/proxy/analyzer/* https://backforge.up.railway.app/frontend-analyzer/:splat  200
/proxy/deploy/*   https://backforge.up.railway.app/deploy/:splat  200
/proxy/sync/*     https://backforge.up.railway.app/sync/:splat  200
/proxy/codegen/*  https://backforge.up.railway.app/generate/:splat  200
/proxy/metrics/*  https://backforge.up.railway.app/metrics/:splat  200

# SPA fallback — all other routes serve index.html
/*  /index.html  200
